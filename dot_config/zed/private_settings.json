{
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false
  },
  "tabs": {
    "show_close_button": "always"
  },
  "proxy": "",
  "cli_default_open_behavior": "existing_window",
  "window_decorations": "server",
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_buffer_font_size": 20.0,
  "agent_ui_font_size": 20.0,
  "ui_font_family": "DankMono Nerd Font",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "html": true,
    "catppuccin": true,
    "rose-pine-theme": true
  },
  "base_keymap": "VSCode",
  "theme": {
    "mode": "dark",
    "dark": "Atom One Dark",
    "light": "Gruvbox Light Soft"
  },
  "icon_theme": {
    "mode": "dark",
    "dark": "Rose Pine Icons",
    "light": "Rose Pine Icons"
  },
  "ui_font_size": 20.0,
  "buffer_font_size": 20.0,
  "buffer_font_family": "DankMono Nerd Font Mono",
  "buffer_line_height": {
    "custom": 1.8
  },
  "terminal": {
    "default_height": 640.0,
    "font_size": 20,
    "font_family": "DankMono Nerd Font Mono",
    "line_height": {
      "custom": 1.4
    }
  },
  "tab_size": 2,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "auto_indent_on_paste": true,
  "format_on_save": "off",
  "use_on_type_format": true,
  "mouse_wheel_zoom": true,
  "cursor_blink": true,
  "cursor_shape": "block",
  "show_whitespaces": "none",
  "soft_wrap": "none",
  "show_wrap_guides": false,
  "indent_guides": {
    "enabled": false
  },
  "minimap": {
    "show": "never"
  },
  "toolbar": {
    "breadcrumbs": false
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": true,
    "show_user_picture": false,
    "show_user_menu": true,
    "show_sign_in": false,
    "show_menus": false,
    "button_layout": "close:minimize,maximize"
  },
  "project_panel": {
    "dock": "right",
    "indent_size": 20,
    "hide_root": true
  },
  "status_bar": {
    "experimental.show": false
  }
}
